generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  bio       String?
  role      String    @default("STUDENT") 
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  tags        String[] 
  pdfUrl      String?  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
}